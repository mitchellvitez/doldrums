--   (>>=) :: m a -> (a -> m b) -> m b

-- standalone type signatures for built-ins
($) :: (a -> b) -> a -> b
(.) :: (b -> c) -> (a -> b) -> a -> c
(&&) :: Bool -> Bool -> Bool
(||) :: Bool -> Bool -> Bool

otherwise = True

not :: Bool -> Bool
not x = if x then False else True

and :: Bool -> Bool -> Bool
and x y = if x then y else False

or :: Bool -> Bool -> Bool
or x y = if x then True else y

xor :: Bool -> Bool -> Bool
xor x y = if x then not y else y

negate :: a -> a
negate x = 0 - x

id :: a -> a
id x = x

const :: a -> b -> a
const x y = x

const2 :: a -> b -> b
const2 x y = y

flip :: (a -> b -> c) -> b -> a -> c
flip f x y = f y x

sCombinator :: (a -> b -> c) -> (a -> b) -> a -> c
sCombinator f g x = f x (g x)

twice :: (a -> a) -> a -> a
twice f = f . f

-- lists
length :: List a -> Int
length [] = 0
length (x:xs) = 1 + length xs

map :: (a -> b) -> List a -> List b
map _ [] = []
map f (x:xs) = f x : map f xs

filter :: (a -> Bool) -> List a -> List a
filter _ [] = []
filter pred (x:xs) = case pred x of
  True -> x : filter pred xs
  False -> filter pred xs

head :: List a -> Maybe a
head [] = Nothing
head (x:_) = Just x

tail :: List a -> List a
tail [] = []
tail (_:xs) = xs

last :: List a -> Maybe a
last Nil = Nothing
last (Cons x Nil) = Just x
last (Cons x xs) = last xs

init :: List a -> List a
init Nil = Nil
init (Cons x (Cons _ Nil)) = Cons x Nil
init (Cons x xs) = Cons x $ init xs

null :: List a -> Bool
null Nil = True
null (Cons _ _) = False

take :: List a -> Int -> List a
take list n = case n <= 0 of
  True -> list
  False -> case list of
    Nil -> Nil
    Cons x xs -> Cons x $ take (n - 1) xs

drop :: List a -> Int -> List a
drop list n = case n <= 0 of
  True -> list
  False -> case list of
    Nil -> Nil
    Cons x xs -> drop (n - 1) xs

elem :: a -> List a -> Bool
elem x Nil = False
elem x (Cons y ys) = x == y || elem x ys

notElem :: a -> List a -> Bool
notElem x xs = not $ elem x xs

seq :: a -> b -> b
seq a b = case a of
  _ -> b

foldl' :: (b -> a -> b) -> b -> List a -> b
foldl' _ acc Nil = acc
foldl' f acc (Cons x xs) = seq acc $ foldl' f (f acc x) xs

{- TODO: awaiting tuples
zip :: [a] -> [b] -> [(a,b)]
zip [] _ = []
zip _ [] = []
zip (a:as) (b:bs) = (a,b) : zip as bs
-}

-- numbers
add x y = x + y
multiply x y = x * y

sum :: Num a => List a -> a
sum = foldl' add 0

product :: Num a => List a -> a
product = foldl' multiply 1

pi = 3.14159265358979323864
e = 2.71828182845904523536

class Enum a where
  succ :: a -> a
  pred :: a -> a

instance Enum Int where
  succ x = x + 1
  pred x = x - 1

mod :: Int -> Int -> Int
mod x y = x - y * x / y

even :: Int -> Bool
even n = mod n 2 == 0

odd :: Int -> Bool
odd = not . even

abs :: Num a => a -> a
abs x
  | x < 0 = negate x
  | otherwise = x

signum :: Num a => a -> a
signum x
  | x < 0 = negate 1
  | x == 0 = 0
  | otherwise = 1

enumFromTo :: Int -> Int -> List Int
enumFromTo start end
  | start <= end = start : enumFromTo (succ start) end
  | otherwise = []

enumFromThenTo :: Int -> Int -> Int -> List Int
enumFromThenTo start next end
  | start <= end = start : enumFromThenTo next (next + next - start) end
  | otherwise = []
