data Bool = True 0 | False 0

if cond then else =
  case cond of
    True -> then
    False -> else

id x = x
const x y = x
const2 x y = y
sCombinator f g x = f x (g x)
compose f g = \x -> f (g x)
twice f = compose f f
negate x = ~x

not x = if x False True
and x y = if x y False
or x y = if x True y
xor x y = if x (not y) y
