-- useful types

data Bool = True | False
  deriving (Eq, Ord, Show)

data Ordering = LT | EQ | GT
  deriving (Eq, Ord, Show)

data Unit = Unit
  deriving (Eq, Ord, Show)

data Tuple2 a b = Tuple2 a b
  deriving (Eq, Ord)

instance (Show a, Show b) => Show (Tuple2 a b) where
  show (a, b) = "(" <> show a <> ", " <> show b <> ")"

data Tuple3 a b c = Tuple3 a b c
  deriving (Eq, Ord)

instance (Show a, Show b, Show c) => Show (Tuple3 a b c) where
  show (a, b, c) = "(" <> show a <> ", " <> show b <> ", " <> show c <> ")"

data Tuple4 a b c d = Tuple4 a b c d
  deriving (Eq, Ord)

instance (Show a, Show b, Show c, Show d) => Show (Tuple4 a b c d) where
  show (a, b, c, d) = "(" <> show a <> ", " <> show b <> ", " <> show c <> ", " <> show d <> ")"

data Tuple5 a b c d e = Tuple5 a b c d e
  deriving (Eq, Ord)

instance (Show a, Show b, Show c, Show d, Show e) => Show (Tuple5 a b c d e) where
  show (a, b, c, d, e) = "(" <> show a <> ", " <> show b <> ", " <> show c <> ", " <> show d <> ", " <> show e <> ")"

-- could keep going with bigger and bigger tuples

data Maybe a = Nothing | Just a
  deriving (Eq, Ord, Show)

data Either a b = Left a | Right b
  deriving (Eq, Ord, Show)

data List a = Nil | Cons a (List a)
  deriving (Eq, Ord, Show)

class Eq a where
  (==) :: a -> a -> Bool
  (/=) :: a -> a -> Bool

class Ord a where
  compare :: a -> a -> Ordering
  (>) :: a -> a -> Bool
  (<) :: a -> a -> Bool
  (>=) :: a -> a -> Bool
  (<=) :: a -> a -> Bool

class Show a where
  show :: a -> String

class Num a where
  (+) :: a -> a -> a
  (-) :: a -> a -> a
  (*) :: a -> a -> a
  (/) :: a -> a -> a
  negate :: a -> a

class Semigroup a where
  (<>) :: a -> a -> a

class Semigroup a => Monoid a where
  mempty :: a

-- class Functor f where
--   (<$>) :: (a -> b) -> f a -> f b
--   fmap :: (a -> b) -> f a -> f b

